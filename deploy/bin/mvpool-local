#!/usr/bin/env bash
# mvpool-local — laptop-side CLI for the MVP pool.
#
# Two roles:
#  1. Passthrough: any unknown subcommand is forwarded over SSH to `mvpool`
#     on the pool server (so `mvpool-local status`, `mvpool-local logs <slug>`,
#     etc., work exactly as if you were on the server).
#  2. Special: `deploy` builds images on the laptop and ships them to the
#     server via the registry (default) or a tarball (`--mode tarball`).
#
# Configure once via env or ~/.config/mvpool/config:
#   MVPOOL_HOST=user@pool-vps.example.com
#   MVPOOL_PORT=22
#   MVPOOL_REGISTRY_USER=mvpool
#   POOL_DOMAIN=example.com   # used to derive registry.${POOL_DOMAIN}
#
# Install on your laptop:
#   ln -sf $(pwd)/deploy/bin/mvpool-local ~/.local/bin/mvpool

set -euo pipefail

# ---------- config --------------------------------------------------------
CONFIG_FILE="${MVPOOL_CONFIG:-$HOME/.config/mvpool/config}"
if [[ -f "$CONFIG_FILE" ]]; then
	# shellcheck disable=SC1090
	. "$CONFIG_FILE"
fi
SSH_HOST="${MVPOOL_HOST:-}"
SSH_PORT="${MVPOOL_PORT:-22}"
SSH_OPTS="${MVPOOL_SSH_OPTS:--o ServerAliveInterval=30}"
POOL_DOMAIN="${POOL_DOMAIN:-}"
BUILD_ON_HOST="${MVPOOL_BUILD_HOST:-}"
BUILD_ON_PORT="${MVPOOL_BUILD_PORT:-22}"
BUILD_EXCLUDES_DEFAULT='.git node_modules .next .turbo dist build out coverage .DS_Store .docker-cache .vscode .idea'
BUILD_EXCLUDES="${MVPOOL_BUILD_EXCLUDES:-$BUILD_EXCLUDES_DEFAULT}"
ARVAN_TOKEN="${MVPOOL_ARVANCLOUD_API_TOKEN:-}"
ARVAN_DOMAIN="${MVPOOL_ARVANCLOUD_DOMAIN:-}"
ARVAN_ORIGIN_IP="${MVPOOL_ARVANCLOUD_ORIGIN_IP:-}"

# Set by cmd_deploy after reading the slug's .meta DOMAIN, used by
# deploy_record + verify + the post-deploy URL print. When a slug's
# user-facing host lives outside POOL_DOMAIN (e.g. Mizro's prototype on
# lab.prototype.mizro.ir while the pool runs under pagio.ir), this is the
# canonical URL — not the synthesized <slug>.<POOL_DOMAIN>. Falls back to
# <slug>.<POOL_DOMAIN> when empty.
DEPLOY_PUBLIC_URL=""

FRAMEWORK_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
TEMPLATES_DIR="$FRAMEWORK_ROOT/templates"

# ---------- style ---------------------------------------------------------
if [[ -t 1 ]]; then
	C_BLUE=$'\033[1;34m'; C_GREEN=$'\033[1;32m'; C_YELLOW=$'\033[1;33m'
	C_RED=$'\033[1;31m'; C_RESET=$'\033[0m'
else
	C_BLUE=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_RESET=""
fi
log()  { printf '%s[mvpool-local]%s %s\n' "$C_BLUE" "$C_RESET" "$*"; }
ok()   { printf '%s\xE2\x9C\x93%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }
warn() { printf '%s[mvpool-local]%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
die()  { printf '%s[mvpool-local]%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing required tool: $1"; }

require_host() {
	[[ -n "$SSH_HOST" ]] || die "set MVPOOL_HOST=user@host (env or $CONFIG_FILE)"
}

# shellcheck disable=SC2086
remote_sh() { ssh $SSH_OPTS -p "$SSH_PORT" "$SSH_HOST" -- "$@"; }
remote_pipe() {
	# usage: cmd_to_send_locally | remote_pipe <remote-cmd...>
	# shellcheck disable=SC2086
	ssh $SSH_OPTS -p "$SSH_PORT" "$SSH_HOST" -- "$@"
}

# ---------- build-host helpers (used when BUILD_ON_HOST is set) -----------
# shellcheck disable=SC2086
build_sh() { ssh $SSH_OPTS -p "$BUILD_ON_PORT" "$BUILD_ON_HOST" -- "$@"; }

build_rsync_excludes() {
	local args=()
	for ex in $BUILD_EXCLUDES; do args+=(--exclude="$ex"); done
	printf '%s\n' "${args[@]}"
}

# ---------- ArvanCloud DNS helper -----------------------------------------
# Idempotently ensure an A record exists for <slug>.<ARVAN_DOMAIN> pointing
# at ARVAN_ORIGIN_IP with cloud-proxy ON. Free-tier ArvanCloud doesn't allow
# proxied wildcards, so each slug needs its own record. No-op if the
# ARVAN_* config triple isn't set.
arvan_dns_ensure() {
	local slug="$1"
	[[ -n "$ARVAN_TOKEN" && -n "$ARVAN_DOMAIN" && -n "$ARVAN_ORIGIN_IP" ]] || return 0
	need curl
	local api="https://napi.arvancloud.ir/cdn/4.0/domains/${ARVAN_DOMAIN}/dns-records"
	local hdr_auth="Authorization: Apikey ${ARVAN_TOKEN}"

	# Check existing records for an exact name match (one API call).
	local existing
	existing="$(curl -fsS --max-time 8 -H "$hdr_auth" -H 'Accept: application/json' \
		"${api}?per_page=200&search=${slug}" 2>/dev/null \
		| python3 -c "
import sys,json
data=json.load(sys.stdin).get('data',[])
match=[x for x in data if x.get('type')=='a' and x.get('name')==sys.argv[1]]
print(match[0]['id'] if match else '')
" "$slug" 2>/dev/null || true)"

	if [[ -n "$existing" ]]; then
		log "arvancloud: record '${slug}.${ARVAN_DOMAIN}' already exists (id=$existing)"
		return 0
	fi

	log "arvancloud: creating A record '${slug}.${ARVAN_DOMAIN}' -> ${ARVAN_ORIGIN_IP} (cloud=on)"
	local body
	body=$(printf '{"type":"a","name":"%s","value":[{"ip":"%s","port":null,"weight":null,"country":""}],"ttl":120,"cloud":true,"upstream_https":"default","ip_filter_mode":{"count":"single","order":"none","geo_filter":"none"}}' \
		"$slug" "$ARVAN_ORIGIN_IP")
	curl -fsS -X POST --max-time 12 \
		-H "$hdr_auth" -H 'Accept: application/json' -H 'Content-Type: application/json' \
		-d "$body" "$api" >/dev/null \
		&& ok   "arvancloud: record created" \
		|| warn "arvancloud: create failed (record may exist already, or the API rejected it — continuing)"
}

# ---------- deploy event log (Hetzner-side) ------------------------------
# Append a single JSONL record to /srv/build/.deploys/deployments.jsonl.
# Best-effort — never fail the deploy because the log write didn't land.
deploy_record() {
	# usage: deploy_record <slug> <tag> <status>
	# Optional metrics passed via env vars (set by cmd_deploy / ship_tarball):
	#   MVPOOL_T_BUILD_S    seconds in the build phase
	#   MVPOOL_T_SHIP_S     seconds in ship_tarball
	#   MVPOOL_T_START_S    seconds in remote deploy/start (compose up)
	#   MVPOOL_T_TOTAL_S    seconds end-to-end
	#   MVPOOL_IMAGE_BYTES  total bytes of image tarballs shipped
	local slug="$1" tag="$2" status="$3"
	[[ -n "$BUILD_ON_HOST" ]] || return 0
	local ts env base actor mode_v url
	ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	actor="$(whoami)@$(hostname -s 2>/dev/null || echo unknown)"
	mode_v="${MODE_FOR_RECORD:-${mode:-tarball}}"
	if   [[ "$slug" == lab-*     ]]; then env="lab";     base="${slug#lab-}"
	elif [[ "$slug" == staging-* ]]; then env="staging"; base="${slug#staging-}"
	elif [[ "$slug" == qa-*      ]]; then env="qa";      base="${slug#qa-}"
	else                                  env="prod";    base="$slug"
	fi
	# Prefer the canonical user-facing URL captured in .meta DOMAIN
	# (set by cmd_deploy → public_url_for_slug). Synthesized fallback
	# only kicks in for slugs that ride the default <slug>.<POOL_DOMAIN>
	# convention.
	url=""
	if   [[ -n "${DEPLOY_PUBLIC_URL:-}" ]]; then url="$DEPLOY_PUBLIC_URL"
	elif [[ -n "${POOL_DOMAIN:-}"       ]]; then url="https://${slug}.${POOL_DOMAIN}"
	fi

	# Build the metrics fragment. Emit only fields we have so old records
	# with no metrics still parse cleanly.
	local metrics=""
	[[ -n "${MVPOOL_T_BUILD_S:-}"   ]] && metrics+=",\"build_s\":${MVPOOL_T_BUILD_S}"
	[[ -n "${MVPOOL_T_SHIP_S:-}"    ]] && metrics+=",\"ship_s\":${MVPOOL_T_SHIP_S}"
	[[ -n "${MVPOOL_T_START_S:-}"   ]] && metrics+=",\"start_s\":${MVPOOL_T_START_S}"
	[[ -n "${MVPOOL_T_TOTAL_S:-}"   ]] && metrics+=",\"total_s\":${MVPOOL_T_TOTAL_S}"
	[[ -n "${MVPOOL_IMAGE_BYTES:-}" ]] && metrics+=",\"image_bytes\":${MVPOOL_IMAGE_BYTES}"

	local record
	# shellcheck disable=SC2016
	record=$(printf '{"ts":"%s","slug":"%s","env":"%s","base":"%s","tag":"%s","status":"%s","actor":"%s","mode":"%s","build_host":"%s","target_host":"%s","url":"%s","job_id":"%s"%s}' \
		"$ts" "$slug" "$env" "$base" "$tag" "$status" "$actor" "$mode_v" "$BUILD_ON_HOST" "$SSH_HOST" "$url" "${MVPOOL_JOB_ID:-}" "$metrics")
	build_sh "mkdir -p /srv/build/.deploys && printf '%s\n' '$record' >> /srv/build/.deploys/deployments.jsonl" >/dev/null 2>&1 || true
}

derive_pool_domain() {
	# Best-effort: pull POOL_DOMAIN from the server's infra .env if we don't
	# have it locally.
	[[ -n "$POOL_DOMAIN" ]] && return
	require_host
	POOL_DOMAIN="$(remote_sh 'grep ^POOL_DOMAIN= /srv/infra/.env 2>/dev/null | cut -d= -f2-' || true)"
	[[ -n "$POOL_DOMAIN" ]] || die "couldn't derive POOL_DOMAIN — set it in $CONFIG_FILE or on the remote infra .env"
}

remote_meta_value() {
	# Read a single key from /srv/apps/<slug>/.meta on the server.
	local slug="$1" key="$2"
	remote_sh "grep ^${key}= /srv/apps/${slug}/.meta 2>/dev/null | cut -d= -f2-" || true
}

# ---------- deploy --------------------------------------------------------
cmd_deploy() {
	# mvpool-local deploy <slug> --from <path> [--type T] [--mode registry|tarball]
	#                            [--tag auto|<custom>] [--static-root <subdir>]
	#                            [--api-dockerfile P] [--web-dockerfile P] [--worker-dockerfile P]
	local slug="" from="" type="" mode="registry" tag="auto"
	local static_root="" cache_mode=""
	local api_df="Dockerfile.api" web_df="Dockerfile.web" worker_df="Dockerfile.worker"
	local app_df="Dockerfile"
	while (($#)); do
		case "$1" in
			--from) from="$2"; shift 2 ;;
			--type) type="$2"; shift 2 ;;
			--mode) mode="$2"; shift 2 ;;
			--tag)  tag="$2";  shift 2 ;;
			--static-root) static_root="$2"; shift 2 ;;
			--cache-mode) cache_mode="$2"; shift 2 ;;
			--build-on)    BUILD_ON_HOST="$2"; shift 2 ;;
			--no-build-on) BUILD_ON_HOST="";   shift   ;;
			--api-dockerfile)    api_df="$2";    shift 2 ;;
			--web-dockerfile)    web_df="$2";    shift 2 ;;
			--worker-dockerfile) worker_df="$2"; shift 2 ;;
			--app-dockerfile)    app_df="$2";    shift 2 ;;
			-*) die "unknown flag: $1" ;;
			*) [[ -z "$slug" ]] && slug="$1" || die "unexpected arg: $1"; shift ;;
		esac
	done
	[[ -n "$slug" ]] || die "usage: mvpool-local deploy <slug> --from <path> [--type T] [--mode registry|tarball] [--build-on <ssh-alias>]"
	[[ -n "$from" && -d "$from" ]] || die "--from <path> must point to an existing directory"
	[[ "$mode" =~ ^(registry|tarball)$ ]] || die "--mode must be 'registry' or 'tarball'"
	require_host
	if [[ -n "$BUILD_ON_HOST" ]]; then
		# remote build: registry mode is incompatible (laptop is the only path that
		# can reach both Hetzner and the Iran VPS — registry hand-off doesn't help)
		[[ "$mode" == "tarball" ]] || die "--build-on requires --mode tarball (Hetzner can't reach the pool registry)"
		log "build host: $BUILD_ON_HOST (remote)"
	else
		need docker
	fi

	# Auto-detect type from the server's meta if not provided.
	if [[ -z "$type" ]]; then
		type="$(remote_meta_value "$slug" TYPE)"
		[[ -n "$type" ]] || die "couldn't read TYPE from /srv/apps/$slug/.meta — pass --type or run mvpool mvp:add first"
	fi
	[[ -d "$TEMPLATES_DIR/$type" ]] || die "unknown --type '$type'"

	# Capture the canonical user-facing URL once (.meta DOMAIN is set by
	# `mvpool mvp:add --domain ...`). When unset, deploy_record falls back to
	# the synthesized <slug>.<POOL_DOMAIN>. Reading the same .meta key would
	# otherwise round-trip to the server on every status update.
	local public_domain
	public_domain="$(remote_meta_value "$slug" DOMAIN)"
	if [[ -n "$public_domain" ]]; then
		DEPLOY_PUBLIC_URL="https://${public_domain}"
	fi

	derive_pool_domain
	local registry_host="registry.${POOL_DOMAIN}"

	# Auto-tag: short git sha if --from is a git repo, else date+rand.
	if [[ "$tag" == "auto" ]]; then
		if (cd "$from" && git rev-parse --short HEAD >/dev/null 2>&1); then
			tag="$(cd "$from" && git rev-parse --short HEAD)"
		else
			tag="$(date -u +%Y%m%d-%H%M%S)-$(openssl rand -hex 3)"
		fi
	fi
	# Ensure the ArvanCloud DNS record exists *before* shipping, so the
	# domain is resolvable as soon as the container is up. Best-effort.
	arvan_dns_ensure "$slug"

	log "deploying '$slug' (type=$type, tag=$tag, mode=$mode)"

	# Status tracking for the dashboard event log. The trap ensures any
	# unexpected exit between 'pending' and 'live' lands as 'failed'.
	MODE_FOR_RECORD="$mode"
	__deploy_last_status=""
	deploy_record_with_track() {
		deploy_record "$slug" "$tag" "$1"
		__deploy_last_status="$1"
	}
	__deploy_on_exit() {
		local rc=$?
		if (( rc != 0 )) && [[ "$__deploy_last_status" != "live" && "$__deploy_last_status" != "" ]]; then
			deploy_record "$slug" "$tag" "failed"
		fi
	}
	trap __deploy_on_exit EXIT

	deploy_record_with_track "pending"

	# Phase timestamps for duration tracking. These get passed to deploy_record
	# via env vars (MVPOOL_T_*) so the dashboard can show "build 42s, ship 1m18s".
	local _t0 _t1 _t2 _t3
	_t0="$(date +%s)"

	# Build per type. Each helper sets BUILT_IMAGES (a list of image names+tags).
	BUILT_IMAGES=()
	case "$type" in
		static)            build_static "$slug" "$from" "$static_root" "$tag" "$registry_host" "$cache_mode" ;;
		node-server)       build_single "$slug" app    "$from" "$app_df"    "$tag" "$registry_host" ;;
		react-node-monorepo)
			build_single "$slug" api "$from" "$api_df" "$tag" "$registry_host"
			build_single "$slug" web "$from" "$web_df" "$tag" "$registry_host"
			[[ -f "$from/$worker_df" ]] && \
				build_single "$slug" worker "$from" "$worker_df" "$tag" "$registry_host"
			;;
		full-stack-queue)
			build_single "$slug" api    "$from" "$api_df"    "$tag" "$registry_host"
			build_single "$slug" web    "$from" "$web_df"    "$tag" "$registry_host"
			build_single "$slug" worker "$from" "$worker_df" "$tag" "$registry_host"
			;;
		*) die "no build recipe for type '$type'" ;;
	esac

	_t1="$(date +%s)"
	export MVPOOL_T_BUILD_S=$(( _t1 - _t0 ))
	deploy_record_with_track "delivering"

	# Ship. Captures total tarball bytes into MVPOOL_IMAGE_BYTES (env).
	export MVPOOL_IMAGE_BYTES=0
	if [[ "$mode" == "registry" ]]; then
		ship_registry
	else
		ship_tarball
	fi

	_t2="$(date +%s)"
	export MVPOOL_T_SHIP_S=$(( _t2 - _t1 ))

	# Trigger remote deploy.
	log "$slug: triggering remote deploy"
	remote_sh "mvpool deploy $slug --tag $tag --mode $mode"

	_t3="$(date +%s)"
	export MVPOOL_T_START_S=$(( _t3 - _t2 ))
	export MVPOOL_T_TOTAL_S=$(( _t3 - _t0 ))

	deploy_record_with_track "live"

	# Pretty summary line.
	local size_mb=""
	if (( MVPOOL_IMAGE_BYTES > 0 )); then
		size_mb=" · image=$(awk -v b="$MVPOOL_IMAGE_BYTES" 'BEGIN{printf "%.1f MB", b/1048576}')"
	fi
	ok "deployed $slug @ $tag — build=${MVPOOL_T_BUILD_S}s ship=${MVPOOL_T_SHIP_S}s start=${MVPOOL_T_START_S}s total=${MVPOOL_T_TOTAL_S}s${size_mb}"
	log "  → ${DEPLOY_PUBLIC_URL:-https://${slug}.${POOL_DOMAIN}}     (or run \`mvpool-local ui\` for the dashboard)"

	# Verify the deployed URL actually answers + matches the tag we just shipped.
	# Best-effort: don't fail the deploy if verification fails (the deploy
	# itself succeeded); just warn loudly. The 'verify-failed' record lets the
	# dashboard surface the issue.
	cmd_verify "$slug" --tag "$tag" || warn "$slug: post-deploy verification failed — site may not be reachable yet"
}

build_static() {
	# Static template is framework-supplied. We materialise a temp build context
	# containing the framework's Dockerfile + the chosen nginx config + the
	# operator's static root, then build with that.
	local slug="$1" from="$2" static_root="$3" tag="$4" registry="$5" cache_mode="${6:-no-cache}"
	[[ -n "$static_root" ]] || die "--static-root <subdir> is required for type=static"
	[[ -d "$from/$static_root" ]] || die "static root '$from/$static_root' does not exist"
	[[ "$cache_mode" =~ ^(no-cache|immutable)$ ]] || die "--cache-mode must be 'no-cache' or 'immutable'"
	[[ -f "$TEMPLATES_DIR/static/nginx-${cache_mode}.conf" ]] || \
		die "missing nginx config $TEMPLATES_DIR/static/nginx-${cache_mode}.conf"

	local tmp; tmp=$(mktemp -d)
	trap "rm -rf '$tmp'" RETURN
	cp "$TEMPLATES_DIR/static/Dockerfile" "$tmp/Dockerfile"
	cp "$TEMPLATES_DIR/static/nginx-no-cache.conf"  "$tmp/nginx-no-cache.conf"
	cp "$TEMPLATES_DIR/static/nginx-immutable.conf" "$tmp/nginx-immutable.conf"
	# Copy the static content as ./content so the Dockerfile's COPY pattern is stable.
	cp -R "$from/$static_root/" "$tmp/content"

	local image="${registry}/${slug}-web:${tag}"
	local build_time; build_time="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

	if [[ -n "$BUILD_ON_HOST" ]]; then
		log "building static image -> $image (cache=${cache_mode}, on $BUILD_ON_HOST)"
		buildx_remote "$slug" "$tmp" "Dockerfile" "$image" "$build_time" \
			--build-arg "STATIC_ROOT=content" \
			--build-arg "CACHE_MODE=$cache_mode"
	else
		log "building static image -> $image (cache=${cache_mode})"
		docker buildx build \
			--platform linux/amd64 \
			--load \
			--build-arg STATIC_ROOT=content \
			--build-arg IMAGE_TAG="$tag" \
			--build-arg BUILD_TIME="$build_time" \
			--build-arg CACHE_MODE="$cache_mode" \
			-t "$image" \
			"$tmp"
	fi
	BUILT_IMAGES+=("$image")
}

build_single() {
	# build_single <slug> <service> <from> <dockerfile-relpath> <tag> <registry>
	local slug="$1" service="$2" from="$3" df="$4" tag="$5" registry="$6"
	[[ -f "$from/$df" ]] || die "$from/$df not found (override with --${service}-dockerfile)"

	local image="${registry}/${slug}-${service}:${tag}"
	local build_time; build_time="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

	if [[ -n "$BUILD_ON_HOST" ]]; then
		log "building $service image -> $image (on $BUILD_ON_HOST)"
		buildx_remote "$slug" "$from" "$df" "$image" "$build_time"
	else
		log "building $service image -> $image"
		docker buildx build \
			--platform linux/amd64 \
			--load \
			--build-arg IMAGE_TAG="$tag" \
			--build-arg BUILD_TIME="$build_time" \
			-f "$from/$df" \
			-t "$image" \
			"$from"
	fi
	BUILT_IMAGES+=("$image")
}

# Run a buildx invocation on $BUILD_ON_HOST.
# Synchronises the build context to /srv/build/<slug>/source/, runs buildx with
# a per-slug local cache, and loads the resulting image into the remote daemon.
buildx_remote() {
	# usage: buildx_remote <slug> <local-context> <dockerfile-relpath> <image> <build-time> [extra buildx flags...]
	local slug="$1" local_ctx="$2" df="$3" image="$4" build_time="$5"
	shift 5
	local remote_src="/srv/build/${slug}/source"
	local cache_dir="/srv/build/${slug}/.buildx-cache"
	local tag="${image##*:}"

	build_sh "mkdir -p $remote_src $cache_dir"
	# shellcheck disable=SC2046
	rsync -a --partial --progress --delete \
		$(build_rsync_excludes) \
		-e "ssh $SSH_OPTS -p $BUILD_ON_PORT" \
		"$local_ctx"/ "${BUILD_ON_HOST}:${remote_src}/"

	# Build extra-args bash-safely (single-quote each, escape interior single-quotes).
	local extras=""
	for a in "$@"; do
		extras+=" '${a//\'/\'\\\'\'}'"
	done
	build_sh "cd $remote_src && \
		docker buildx build --builder mvpool-builder --platform linux/amd64 --load \
		--cache-to type=local,dest=$cache_dir,mode=max,compression=zstd \
		--cache-from type=local,src=$cache_dir \
		--build-arg IMAGE_TAG='$tag' \
		--build-arg BUILD_TIME='$build_time' \
		$extras \
		-f $df -t '$image' ."
}

ship_registry() {
	for image in "${BUILT_IMAGES[@]}"; do
		log "pushing $image"
		docker push "$image"
	done
}

ship_tarball() {
	if [[ -n "$BUILD_ON_HOST" ]]; then
		ship_tarball_via_build_host
	else
		ship_tarball_local
	fi
}

ship_tarball_local() {
	# Pipe `docker save` straight into `ssh ... docker load`.
	# This avoids a stage-on-disk and keeps the image tags intact.
	for image in "${BUILT_IMAGES[@]}"; do
		log "shipping (tarball) $image"
		# shellcheck disable=SC2086
		docker save "$image" | gzip | \
			ssh $SSH_OPTS -p "$SSH_PORT" "$SSH_HOST" -- 'gzip -dc | docker load'
	done
}

# Two-rsync ship via the laptop. Save image to zstd tarball on the build host,
# rsync to laptop (resumable), rsync laptop -> pool VPS (resumable), then ssh-load.
# Resilience: each rsync uses --partial so a dropped Iran↔laptop link picks up
# where it left off instead of restarting from zero (per restricted-network.md
# field findings #4 + #8).
ship_tarball_via_build_host() {
	local stage; stage="$(mktemp -d -t mvpool-ship.XXXXXX)"
	# shellcheck disable=SC2064
	trap "rm -rf '$stage'" RETURN

	for image in "${BUILT_IMAGES[@]}"; do
		# Sanitise the image string for filenames: registry.host/slug-svc:tag → slug-svc-tag
		local fname; fname="$(printf '%s' "${image##*/}" | tr ':/' '--').tar.zst"
		local remote_tar="/srv/build/.ship/$fname"
		local local_tar="$stage/$fname"
		local pool_tar="/tmp/$fname"

		log "saving on $BUILD_ON_HOST: $image -> $remote_tar"
		build_sh "mkdir -p /srv/build/.ship && docker save '$image' | zstd -T0 -3 > '$remote_tar'"

		# Capture tarball size (bytes) for the deploy record.
		local img_bytes
		img_bytes="$(build_sh "stat -c '%s' '$remote_tar' 2>/dev/null || stat -f '%z' '$remote_tar'" 2>/dev/null | tr -d '\r' | head -1 || true)"
		if [[ "$img_bytes" =~ ^[0-9]+$ ]]; then
			MVPOOL_IMAGE_BYTES=$(( ${MVPOOL_IMAGE_BYTES:-0} + img_bytes ))
			export MVPOOL_IMAGE_BYTES
			log "tarball size: $(awk -v b="$img_bytes" 'BEGIN{printf "%.1f MB", b/1048576}')"
		fi

		log "rsync $BUILD_ON_HOST -> laptop ($fname)"
		# shellcheck disable=SC2086
		rsync -a --partial --progress \
			-e "ssh $SSH_OPTS -p $BUILD_ON_PORT" \
			"${BUILD_ON_HOST}:${remote_tar}" "$local_tar"

		log "rsync laptop -> $SSH_HOST ($fname)"
		# shellcheck disable=SC2086
		rsync -a --partial --progress \
			-e "ssh $SSH_OPTS -p $SSH_PORT" \
			"$local_tar" "${SSH_HOST}:${pool_tar}"

		log "loading on $SSH_HOST"
		remote_sh "zstd -dc < '$pool_tar' | docker load && rm -f '$pool_tar'"

		# Drop the laptop staging copy as we go to bound disk use on big multi-image deploys.
		rm -f "$local_tar"
	done
}

# ---------- ui (open the deploy dashboard) -------------------------------
cmd_ui() {
	# `mvpool-local ui` — open / refresh the deploy dashboard.
	# Wraps dashboard/open.sh which establishes (or reuses) an SSH tunnel
	# to the dashboard service on the build host and opens the browser.
	#
	# Sub-flags forward to dashboard/open.sh:
	#   mvpool-local ui              # open
	#   mvpool-local ui --close      # tear down the tunnel
	#   mvpool-local ui --reload     # rsync local changes + kick bun + reopen
	local script="${FRAMEWORK_ROOT}/../dashboard/open.sh"
	[[ -x "$script" ]] || die "missing dashboard/open.sh at $script"
	exec bash "$script" "$@"
}

# ---------- arvan:ensure -------------------------------------------------
cmd_arvan_ensure() {
	local slug="${1:-}"
	[[ -n "$slug" ]] || die "usage: mvpool-local arvan:ensure <slug>"
	[[ -n "$ARVAN_TOKEN" && -n "$ARVAN_DOMAIN" && -n "$ARVAN_ORIGIN_IP" ]] || \
		die "set MVPOOL_ARVANCLOUD_API_TOKEN, _DOMAIN, _ORIGIN_IP in $CONFIG_FILE"
	arvan_dns_ensure "$slug"
}

# ---------- verify -------------------------------------------------------
# Resolve the deployed URL via the authoritative ArvanCloud nameserver
# (bypasses Shadowrocket fakedns + ISP recursive caching), curl /api/version
# and /version.txt, parse the tag, compare to the expected tag. Append a
# 'verified' or 'verify-failed' deploy_record so the dashboard can show it.
#
# Usage:
#   mvpool-local verify <slug>                # uses CURRENT_TAG from .meta
#   mvpool-local verify <slug> --tag <tag>    # explicit
cmd_verify() {
	local slug="${1:-}" expected=""
	[[ -n "$slug" ]] || die "usage: mvpool-local verify <slug> [--tag <tag>]"
	shift
	while (($#)); do
		case "$1" in
			--tag) expected="$2"; shift 2 ;;
			*) die "unknown flag: $1" ;;
		esac
	done

	# Prefer the canonical .meta DOMAIN so verify hits whatever the slug is
	# actually serving on (e.g. lab.prototype.mizro.ir), not the synthesized
	# <slug>.<POOL_DOMAIN>. Falls back to the synthesized form only when
	# .meta has no DOMAIN — the legacy default for slugs that ride the
	# pool's own zone.
	local domain
	domain="$(remote_meta_value "$slug" DOMAIN)"
	if [[ -z "$domain" ]]; then
		derive_pool_domain
		domain="${slug}.${POOL_DOMAIN}"
	fi

	if [[ -z "$expected" ]]; then
		expected="$(remote_meta_value "$slug" CURRENT_TAG)"
		[[ -n "$expected" ]] || die "couldn't read CURRENT_TAG from server; pass --tag <tag>"
	fi

	log "verify: ${domain} expected tag=${expected}"

	# Resolve via authoritative ArvanCloud NS first (avoids Shadowrocket
	# fakedns 198.18.x and Iran ISP recursive resolvers that often fail
	# Cloudflare-anycast NSes). Fall back to system DNS, then to the
	# pool VPS's known origin IP. dig with `+short` writes errors like
	# "connection timed out" to stdout on failure, so we have to validate
	# that what came back is actually an IP.
	# pipefail + dig-timeout would exit -e the whole script silently — guard
	# every command-sub with `|| true` so we keep going through fallbacks.
	local edge_ip="" raw=""
	for ns in '@v.ns.arvancdn.ir' ''; do
		# shellcheck disable=SC2086
		raw="$( { dig +short +time=3 +tries=1 $ns "$domain" A 2>/dev/null || true; } | head -1 || true)"
		if [[ "$raw" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
			edge_ip="$raw"
			break
		fi
	done

	# Last-resort fallback: hit the origin IP directly (skips ArvanCloud
	# edge — won't validate TLS/CDN, but does prove the container responds).
	local hit_origin=0
	if [[ -z "$edge_ip" && -n "$ARVAN_ORIGIN_IP" ]]; then
		warn "verify: DNS unreachable — falling back to origin IP ${ARVAN_ORIGIN_IP} (no edge TLS check)"
		edge_ip="$ARVAN_ORIGIN_IP"
		hit_origin=1
	fi

	[[ -n "$edge_ip" ]] || { warn "verify: couldn't resolve $domain — skipping"; deploy_record "$slug" "$expected" "verify-failed"; return 1; }

	# Try /api/version (node-server shape) then /version.txt (static shape).
	# Retry up to 5x with short backoff for fresh ArvanCloud DNS records.
	# When falling back to origin IP (no DNS), hit HTTP/80 directly with
	# Host header — origin Caddy in restricted-network mode is HTTP-only.
	local proto resolve_arg curl_extra
	if (( hit_origin )); then
		proto="http"
		resolve_arg="--resolve ${domain}:80:${edge_ip}"
		curl_extra="-H Host:${domain}"
	else
		proto="https"
		resolve_arg="--resolve ${domain}:443:${edge_ip}"
		curl_extra=""
	fi

	local actual="" body="" code="" attempt=0 path=""
	for path in /api/version /version.txt; do
		for attempt in 1 2 3 4 5; do
			# shellcheck disable=SC2086
			body="$(curl -sk --max-time 5 $resolve_arg $curl_extra "${proto}://${domain}${path}" 2>/dev/null)" || true
			# shellcheck disable=SC2086
			code="$(curl -sk --max-time 5 -o /dev/null -w '%{http_code}' $resolve_arg $curl_extra "${proto}://${domain}${path}" 2>/dev/null || echo 000)"
			if [[ "$code" == "200" && -n "$body" ]]; then break 2; fi
			sleep 2
		done
	done

	if [[ "$code" != "200" || -z "$body" ]]; then
		warn "verify: ${domain} not reachable (last http=${code})"
		deploy_record "$slug" "$expected" "verify-failed"
		return 1
	fi

	# Extract tag — try JSON .tag, then 'tag=' line.
	if [[ "$body" == *'"tag"'* ]]; then
		actual="$(printf '%s' "$body" | python3 -c "import sys,json
try: print(json.load(sys.stdin).get('tag',''))
except: pass" 2>/dev/null)"
	fi
	if [[ -z "$actual" ]]; then
		actual="$(printf '%s\n' "$body" | grep -oE '^tag=[A-Za-z0-9._-]+' | head -1 | cut -d= -f2)"
	fi

	if [[ "$actual" == "$expected" ]]; then
		ok "verify: ${domain} returns tag=${actual} ✓"
		deploy_record "$slug" "$expected" "verified"
		return 0
	else
		warn "verify: ${domain} returns tag='${actual}', expected '${expected}'"
		deploy_record "$slug" "$expected" "verify-failed"
		return 1
	fi
}

# ---------- login --------------------------------------------------------
cmd_login() {
	derive_pool_domain
	local registry_host="registry.${POOL_DOMAIN}"
	local user="${MVPOOL_REGISTRY_USER:-mvpool}"
	log "docker login $registry_host (user=$user)"
	docker login "$registry_host" -u "$user"
}

# ---------- dispatch ------------------------------------------------------
usage() {
	cat <<'EOF'
mvpool-local — laptop-side CLI for the MVP pool.

Special commands (run locally):
  deploy <slug> --from <path> [--type T] [--mode registry|tarball]
                              [--tag auto|<custom>] [--static-root SUBDIR]
                              [--cache-mode no-cache|immutable]   (static only)
                              [--build-on <ssh-alias>]            (remote build)
                              [--api-dockerfile P] [--web-dockerfile P]
                              [--worker-dockerfile P] [--app-dockerfile P]
                              builds images locally OR on a remote build host,
                              ships them, then triggers
                              `mvpool deploy <slug> --tag <tag>` on the server.

                              --build-on <alias>: rsync the build context to
                              <alias>:/srv/build/<slug>/source/, run docker
                              buildx there, save → zstd, two-rsync via the
                              laptop to the pool VPS, ssh-load. Requires
                              --mode tarball. Set MVPOOL_BUILD_HOST in your
                              config to make this the default; pass
                              --no-build-on to override back to local.
  verify <slug> [--tag T]     Curl the deployed URL, parse /api/version or
                              /version.txt, confirm the tag matches the one
                              we expect to be live. Auto-runs at the end of
                              every `deploy`; useful standalone to re-check.
  ui [--reload|--close]       Open the deploy dashboard via an SSH tunnel
                              to the build host. --reload pushes local
                              dashboard/ changes + kicks the bun process.
  arvan:ensure <slug>         Idempotently create the ArvanCloud A record
                              for <slug>.${MVPOOL_ARVANCLOUD_DOMAIN} with
                              cloud=ON. Auto-runs as part of `deploy`.
  login                       `docker login` to registry.${POOL_DOMAIN}.

Everything else is forwarded to the server's `mvpool` over SSH:
  mvpool-local status
  mvpool-local infra:up
  mvpool-local mvp:add <slug> --type static
  mvpool-local mvp:list
  mvpool-local logs <slug> [service]
  mvpool-local rollback <slug> <tag>
  ...

Config (env or ~/.config/mvpool/config):
  MVPOOL_HOST=user@pool-vps.example.com   (required)
  MVPOOL_PORT=22
  MVPOOL_SSH_OPTS=
  MVPOOL_REGISTRY_USER=mvpool
  POOL_DOMAIN=example.com                 (auto-derived from server if absent)
  MVPOOL_BUILD_HOST=ali@build-vps         (optional; default for --build-on)
  MVPOOL_BUILD_PORT=22
  MVPOOL_BUILD_EXCLUDES='.git node_modules .next ...'  (rsync excludes)
EOF
}

main() {
	local sub="${1:-}"; shift || true
	case "$sub" in
		deploy)            cmd_deploy "$@" ;;
		verify)            cmd_verify "$@" ;;
		ui|dashboard)      cmd_ui "$@" ;;
		arvan:ensure)      cmd_arvan_ensure "$@" ;;
		login)             cmd_login "$@" ;;
		""|-h|--help|help) usage ;;
		# Catch-all: forward to the remote `mvpool` CLI. Allocate a TTY for
		# subcommands that benefit from one (logs -f, db:psql, etc.).
		*)
			require_host
			local tty_flag=""
			case "$sub" in
				logs|infra:logs|db:psql) tty_flag="-t" ;;
			esac
			# shellcheck disable=SC2086
			exec ssh $SSH_OPTS -p "$SSH_PORT" $tty_flag "$SSH_HOST" -- mvpool "$sub" "$@"
			;;
	esac
}

main "$@"
