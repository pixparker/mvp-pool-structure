# Shared-infra env. Lives at /srv/infra/.env on the server.
# Generate strong values before first `docker compose up`.

# Caddy / TLS
ACME_EMAIL=admin@example.com

# Pool umbrella domain. Each MVP defaults to <slug>.${POOL_DOMAIN} unless
# `mvpool mvp:add ... --domain custom.example.com` is passed.
# Caddy also serves the registry at registry.${POOL_DOMAIN}.
POOL_DOMAIN=example.com

# Postgres admin credentials (the superuser that mvpool uses to create per-MVP DBs/roles)
POSTGRES_ADMIN_USER=mvpool_admin
POSTGRES_ADMIN_PASSWORD=generate-with-openssl-rand-base64-32
